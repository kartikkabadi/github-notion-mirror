# Notion
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=
NOTION_VERSION=2026-03-11

# Filled by `mirror init` (can also set manually)
NOTION_REPOS_DATA_SOURCE_ID=
NOTION_WORK_ITEMS_DATA_SOURCE_ID=

# GitHub App (preferred; Phase 2)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# OR fine-grained PAT for Phase 1 backfill only
GITHUB_TOKEN=

# Server
HOST=127.0.0.1
PORT=4317
LOG_LEVEL=info

# Sync policy
RECONCILE_INTERVAL_MINUTES=15
MAX_NOTION_RPS=2
MAX_JOB_ATTEMPTS=8
BACKFILL_INCLUDE_CLOSED=false
MAX_COMMENTS_PER_ITEM=50
MAX_BODY_CHARS=100000
MAX_CHANGED_FILES_LISTED=100
MAPPER_VERSION=1
